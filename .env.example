DATABASE_URL="file:./dev.db"
JWT_SECRET="thay_bang_random_64_hex_characters"
PORT=25113
FRONTEND_URL="http://localhost:25113"
NODE_ENV="development"
# SSL (optional - only for HTTPS in production)
# SSL_CERT_PATH="./ssl/cert.pem"
# SSL_KEY_PATH="./ssl/key.pem"
#
# Discord OAuth (for player login)
# Create an app at https://discord.com/developers/applications
# OAuth2 → Redirects: add http://localhost:25113/api/discord/callback (dev) and your production URL
# DISCORD_CLIENT_ID="your_client_id_here"
# DISCORD_CLIENT_SECRET="your_client_secret_here"
# DISCORD_REDIRECT_URI="http://localhost:25113/api/discord/callback"
#
# Discord Bot (for slash commands + DM reminders)
# Bot → Reset Token to get the token, then toggle Server Members Intent + Message Content Intent
# Invite URL: https://discord.com/api/oauth2/authorize?client_id=CLIENT_ID&permissions=2147485696&scope=bot%20applications.commands
# DISCORD_BOT_TOKEN="your_bot_token_here"
# DISCORD_GUILD_ID="your_server_id_here" (optional — guild = instant, global = up to 1h delay)
#
# === PRODUCTION DATABASE RECOMMENDATION ===
# SQLite (current) is fine for small tournaments.
# For higher concurrency, switch to PostgreSQL:
# 1. Change provider in prisma/schema.prisma from "sqlite" to "postgresql"
# 2. Set DATABASE_URL="postgresql://user:password@host:5432/evancup"
# 3. Run: npx prisma migrate deploy
# 4. Update docker-compose.yml to add a postgres service
